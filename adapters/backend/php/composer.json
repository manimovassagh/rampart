{
    "name": "rampart/laravel",
    "description": "Laravel & PSR-15 middleware adapter for Rampart IAM — JWT verification with RBAC",
    "version": "0.1.0",
    "type": "library",
    "license": "MIT",
    "keywords": ["rampart", "jwt", "oauth2", "oidc", "laravel", "middleware", "psr-15", "rbac"],
    "homepage": "https://github.com/manimovassagh/rampart",
    "authors": [
        {
            "name": "Mani Movassagh",
            "homepage": "https://github.com/manimovassagh"
        }
    ],
    "require": {
        "php": "^8.1",
        "firebase/php-jwt": "^6.8",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "orchestra/testbench": "^8.0|^9.0"
    },
    "autoload": {
        "psr-4": {
            "Rampart\\Laravel\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Rampart\\Laravel\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Rampart\\Laravel\\RampartServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
