{
  "name": "@rampart/web",
  "version": "0.1.0",
  "description": "Rampart authentication client for browsers and frontend apps",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "lint": "tsc --noEmit",
    "test": "vitest run"
  },
  "keywords": [
    "rampart",
    "auth",
    "client",
    "oidc",
    "jwt",
    "frontend"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/manimovassagh/rampart",
    "directory": "adapters/frontend/web"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "~5.7.0",
    "vitest": "^3.0.0"
  }
}
